{
  "name": "@custom/terminal-cursor",
  "version": "0.1.0",
  "description": "Adds >_ terminal cursor effect to the page title.",
  "type": "module",
  "license": "MIT",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./components": {
      "types": "./dist/components/index.d.ts",
      "import": "./dist/components/index.js"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "quartz": {
    "name": "terminal-cursor",
    "displayName": "Terminal Cursor",
    "category": "component",
    "version": "0.1.0",
    "quartzVersion": ">=5.0.0",
    "dependencies": [],
    "defaultOrder": 11,
    "defaultEnabled": true,
    "defaultOptions": {},
    "components": {
      "TerminalCursor": {
        "displayName": "Terminal Cursor",
        "defaultPosition": "left",
        "defaultPriority": 11
      }
    }
  }
}
